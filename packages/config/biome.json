{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "root": false,
  "files": {
    "includes": [
      "**",
      "!!**/node_modules",
      "!!**/dist",
      "!!**/.next",
      "!!**/.turbo",
      "!!**/convex/_generated",
      "!!apps/web/app/globals.css",
      "!!apps/extension/src/popup/index.css",
      "!!packages/config/tailwind/base.css",
      "!!packages/config/tailwind/theme.css"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "useImportType": "error"
      },
      "suspicious": {
        "noExplicitAny": "error"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "asNeeded",
      "trailingCommas": "es5"
    }
  },
  "json": {
    "formatter": {
      "enabled": true
    }
  }
}
